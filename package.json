{
	"name": "nestjs-open-source-template",
	"description": "📜 My template for creating NestJS Open Source projects",
	"version": "1.0.0",
	"scripts": {
		"build": "rimraf -rf dist && tsc -p tsconfig.build.json",
		"prepublish:npm": "npm run build",
		"publish:npm": "release-it",
		"prepublish:dev": "npm run build",
		"publish:dev": "npm publish --access public --tag dev",
		"prepare": "husky",
		"format": "prettier --write \"{src,apps,libs,test}/**/*.ts\"",
		"lint": "eslint --ignore-pattern .gitignore \"{src,apps,libs,test}/**/*.ts\"",
		"lint:fix": "npm run lint -- --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:ci": "jest --ci --passWithNoTests --coverage"
	},
	"lint-staged": {
		"*.ts": [
			"npm run format",
			"npm run lint:fix"
		]
	},
	"directories": {
		"lib": "src",
		"test": "test"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"keywords": [],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SocketSomeone/nestjs-open-source-template.git"
	},
	"bugs": {
		"url": "https://github.com/SocketSomeone/nestjs-open-source-template"
	},
	"author": "Alexey Filippov <socket.someone@gmail.com>",
	"contributors": [
		"Alexey Filippov <socket.someone@gmail.com>"
	],
	"dependencies": {
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@commitlint/cli": "21.2.1",
		"@commitlint/config-angular": "21.2.0",
		"@eslint/eslintrc": "^3.3.6",
		"@eslint/js": "^10.0.1",
		"@nestjs/common": "11.1.28",
		"@nestjs/core": "11.1.28",
		"@nestjs/testing": "^11.1.28",
		"@release-it/conventional-changelog": "^11.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "26.1.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-perfectionist": "^5.10.0",
		"eslint-plugin-prettier": "5.5.6",
		"globals": "^17.7.0",
		"husky": "9.1.7",
		"jest": "^30.4.2",
		"lint-staged": "17.1.0",
		"prettier": "3.9.5",
		"reflect-metadata": "0.2.2",
		"release-it": "20.2.1",
		"rimraf": "6.1.3",
		"rxjs": "7.8.2",
		"ts-jest": "^29.4.11",
		"ts-node": "10.9.2",
		"typescript": "7.0.2",
		"typescript-eslint": "^8.64.0"
	},
	"peerDependencies": {
		"@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
		"@nestjs/core": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
		"reflect-metadata": "^0.2.1",
		"rxjs": "^7.2.0"
	}
}
